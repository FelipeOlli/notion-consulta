generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppModule {
  SENHA
  CERTIFICADOS
  FINANCEIRO
  USUARIOS
  CADASTRO_EMPRESA
  ALTERDATA
  CHIPS
  DOMINIO
}

enum DominioSscStatus {
  ABERTA
  RESOLVIDA
}

enum ChipOperadora {
  CLARO
  TIM
  VIVO
  OI
}

enum AlterdataClienteStatus {
  ATIVO
  EM_ANDAMENTO
  INATIVO
  INADIMPLENTE
  CONGELADO
  DISTRATADO
}

enum AlterdataCredencialTipo {
  ECONTADOR
  NUVEM
  PACK
}

enum AlterdataTelemetria {
  ATIVO
  INATIVO
}

enum UsageSource {
  MANUAL
  IMPORT
}

/** Origem do arquivo na importação do dashboard financeiro. */
enum SnapshotImportSource {
  GOOGLE_JSON
  GOOGLE_CSV
  TIM_CSV
}

/** Linha veio do arquivo de importação ou foi cadastrada manualmente no portal. */
enum SnapshotLineSource {
  IMPORTED
  MANUAL
}

/** Ações auditadas no módulo Financeiro (admin). */
enum FinanceiroActivityAction {
  IMPORT_SNAPSHOT
  COMPANY_CREATE
  COMPANY_RENAME
  COMPANY_DELETE
  LINE_CREATE
  LINE_UPDATE
  LINE_DELETE
  LINE_BULK_ALLOCATE
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  passwordHash  String
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  moduleAccess  UserModuleAccess[]
}

model UserModuleAccess {
  id        String    @id @default(cuid())
  userId    String
  module    AppModule
  canRead   Boolean   @default(true)
  canWrite  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module])
}

model Company {
  id                String               @id @default(cuid())
  legalName         String
  document          String?              @unique
  partnerName       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  collaborators     Collaborator[]
  certificates      DigitalCertificate[]
  emailUsages       EmailUsage[]
  monitoringCosts   MonitoringCost[]
}

model Collaborator {
  id          String       @id @default(cuid())
  fullName    String
  /** E-mail de identificação nos serviços CF (.COM / .COM.BR). Obrigatório quando há vínculo com esses serviços. */
  workEmail   String?
  companyId   String
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments CollaboratorServerAssignment[]
  emailUsages EmailUsage[]
}

model DigitalCertificate {
  id                   String    @id @default(cuid())
  companyId            String
  certificatePassword  String
  expiresAt            DateTime
  filePath             String
  fileName             String
  fileSize             Int
  mimeType             String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model EmailServer {
  id                        String       @id @default(cuid())
  name                      String       @unique
  costPerEmail              Decimal      @db.Decimal(12, 6)
  /** Se true, colaboradores neste serviço exigem workEmail (ex.: CF .COM e .COM.BR). Time Is Money = false. */
  requiresCollaboratorEmail Boolean      @default(true)
  active                    Boolean      @default(true)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  collaboratorAssignments   CollaboratorServerAssignment[]
  emailUsages               EmailUsage[]
  userSnapshots             ServiceUserSnapshot[]
  /** Cadastro de empresas para alocação no dashboard financeiro (por serviço). */
  financeiroCompanies       FinanceiroServerCompany[]
}

/** Empresa cadastrada por servidor de e-mail (CF .COM / .COM.BR / Time Is Money) para alocar linhas de snapshot. */
model FinanceiroServerCompany {
  id        String   @id @default(cuid())
  serverId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  server    EmailServer               @relation(fields: [serverId], references: [id], onDelete: Cascade)
  lines     ServiceUserSnapshotLine[]

  @@unique([serverId, name])
  @@index([serverId])
}

/** Snapshot mensal de quantidade de usuários por serviço (dashboard financeiro). */
model ServiceUserSnapshot {
  id          String                    @id @default(cuid())
  serverId    String
  /** Primeiro dia do mês de competência (UTC). */
  competence  DateTime
  totalUsers  Int
  /** Preenchido em exports Google Workspace; null no Time Is Money. */
  activeUsers Int?
  source      SnapshotImportSource
  fileName    String?
  createdAt   DateTime                  @default(now())
  server      EmailServer               @relation(fields: [serverId], references: [id], onDelete: Cascade)
  lines       ServiceUserSnapshotLine[]

  @@unique([serverId, competence])
}

/** Linha importada (visualização em planilha); alocação por empresa via FinanceiroServerCompany. */
model ServiceUserSnapshotLine {
  id                        String                   @id @default(cuid())
  snapshotId                String
  sortOrder                 Int
  email                     String?
  displayName               String
  /** Legado; métricas usam financeiroServerCompany. */
  companyLabel              String
  companyLabelOverride      String?
  /** Empresa alocada para métricas e filtros (catálogo do mesmo servidor do snapshot). */
  financeiroServerCompanyId String?
  financeiroServerCompany   FinanceiroServerCompany? @relation(fields: [financeiroServerCompanyId], references: [id], onDelete: SetNull)
  status                    String?
  detail                    String?
  meta                      Json?
  lineSource                SnapshotLineSource         @default(IMPORTED)
  snapshot                  ServiceUserSnapshot      @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([snapshotId, companyLabel])
  @@index([snapshotId, financeiroServerCompanyId])
}

/** Registro append-only de movimentações na área financeira (admin). */
model FinanceiroActivityLog {
  id          String                   @id @default(cuid())
  createdAt   DateTime                 @default(now())
  actorEmail  String
  actorUserId String?
  action      FinanceiroActivityAction
  metadata    Json?

  @@index([createdAt])
  @@index([action, createdAt])
}

model CollaboratorServerAssignment {
  id             String        @id @default(cuid())
  collaboratorId String
  serverId       String
  createdAt      DateTime      @default(now())
  collaborator   Collaborator  @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  server         EmailServer   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([collaboratorId, serverId])
}

model EmailUsage {
  id              String        @id @default(cuid())
  serverId        String
  companyId       String
  collaboratorId  String?
  emailsCount     Int
  competence      DateTime
  source          UsageSource   @default(MANUAL)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  server          EmailServer   @relation(fields: [serverId], references: [id], onDelete: Restrict)
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  collaborator    Collaborator? @relation(fields: [collaboratorId], references: [id], onDelete: SetNull)
}

model MonitoringCost {
  id         String    @id @default(cuid())
  companyId  String
  unitCost   Decimal   @db.Decimal(12, 2)
  competence DateTime
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum IpMonitorType {
  HTTP
  TCP
  PING
}

enum IpMonitorStatus {
  PENDING
  UP
  DOWN
}

model IpMonitorGroup {
  id        String      @id @default(cuid())
  name      String
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  monitors  IpMonitor[]
}

model IpMonitor {
  id          String           @id @default(cuid())
  name        String
  host        String
  port        Int?
  type        IpMonitorType    @default(HTTP)
  groupId     String?
  group       IpMonitorGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  active      Boolean          @default(true)
  interval    Int              @default(60)
  lastStatus  IpMonitorStatus  @default(PENDING)
  lastChecked DateTime?
  lastPing    Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  events      IpMonitorEvent[]
  protocols   IpMonitorProtocol[]

  @@index([groupId])
}

model IpMonitorEvent {
  id        String          @id @default(cuid())
  monitorId String
  monitor   IpMonitor       @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status    IpMonitorStatus
  ping      Int?
  message   String?
  createdAt DateTime        @default(now())

  @@index([monitorId, createdAt])
}

model IpMonitorProtocol {
  id           String                   @id @default(cuid())
  monitorId    String
  monitor      IpMonitor                @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  protocol     String
  serviceOrder String
  observacao   String?
  anexos       IpMonitorProtocolAnexo[]
  createdAt    DateTime                 @default(now())

  @@index([monitorId, createdAt])
}

model IpMonitorProtocolAnexo {
  id         String            @id @default(cuid())
  protocolId String
  protocol   IpMonitorProtocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  filePath   String
  fileName   String
  fileSize   Int
  mimeType   String
  createdAt  DateTime          @default(now())

  @@index([protocolId])
}

model AlterdataCliente {
  id                String                        @id @default(cuid())
  codPessoa         String                        @unique
  nome              String
  unidade           String?
  cnpj              String?
  status            AlterdataClienteStatus        @default(ATIVO)
  telemetria        AlterdataTelemetria?
  qtdLicencas       Int                           @default(1)
  qtdUsuarios       Int                           @default(0)
  acessosFranqueado Int                           @default(0)
  acessosBackoffice Int                           @default(0)
  observacao        String?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  observacoes       AlterdataClienteObservacao[]
  contadores        AlterdataClienteContador[]

  @@index([status])
}

model AlterdataClienteObservacao {
  id          String                       @id @default(cuid())
  clienteId   String
  cliente     AlterdataCliente             @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  texto       String
  authorEmail String
  editedAt    DateTime?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
  anexos      AlterdataObservacaoAnexo[]

  @@index([clienteId, createdAt])
}

model AlterdataObservacaoAnexo {
  id           String                     @id @default(cuid())
  observacaoId String
  observacao   AlterdataClienteObservacao @relation(fields: [observacaoId], references: [id], onDelete: Cascade)
  filePath     String
  fileName     String
  fileSize     Int
  mimeType     String
  createdAt    DateTime                   @default(now())

  @@index([observacaoId])
}

model AlterdataClienteContador {
  id        String                   @id @default(cuid())
  clienteId String
  cliente   AlterdataCliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tipo      AlterdataCredencialTipo  @default(ECONTADOR)
  login     String
  senha     String
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@index([clienteId, tipo])
}

model ChipEmpresa {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  chips     Chip[]
}

model Chip {
  id            String        @id @default(cuid())
  numero        String
  operadora     ChipOperadora
  empresaId     String
  empresa       ChipEmpresa   @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  ultimaRecarga DateTime
  duracaoDias   Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([empresaId])
  @@index([ultimaRecarga])
}

model DominioSsc {
  id            String             @id @default(cuid())
  numero        String             @unique
  assunto       String?
  status        DominioSscStatus   @default(ABERTA)
  criadoPor     String?
  lastCheckedAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  updates       DominioSscUpdate[]

  @@index([status])
}

model DominioSscUpdate {
  id             String     @id @default(cuid())
  sscId          String
  ssc            DominioSsc @relation(fields: [sscId], references: [id], onDelete: Cascade)
  gmailMessageId String
  remetente      String?
  assunto        String?
  snippet        String?
  receivedAt     DateTime?
  visto          Boolean    @default(false)
  createdAt      DateTime   @default(now())

  @@unique([sscId, gmailMessageId])
  @@index([sscId, createdAt])
}

enum TiTaskStatus {
  TODO
  DOING
  DONE
}

enum TiTaskType {
  MANUAL
  AUTOMACAO
  DELEGACAO
}

model TiTask {
  id          String       @id @default(cuid())
  code        String       @unique
  title       String
  description String?
  responsible String
  status      TiTaskStatus @default(TODO)
  taskType    TiTaskType   @default(MANUAL)
  raciRef     String?
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
